{
  "expo": {
    "name": "CityWhispers",
    "slug": "citywhispers",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f0e0c"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.citywhispers.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f0e0c"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.citywhispers.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "scheme": "citywhispers",
    "plugins": [
      "expo-router",
      "expo-location",
      "expo-secure-store",
      "expo-web-browser"
    ]
  }
}
