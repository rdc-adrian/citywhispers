{
  "name": "@citywhispers/api",
  "version": "0.0.1",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "db:push": "prisma db push",
    "db:pull": "prisma db pull",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed-all": "tsx prisma/seed-all.ts",
    "db:seed-pois": "tsx scripts/seed-poi-production.ts",
    "db:approve-sg": "tsx scripts/approve-sg-whispers.ts",
    "backup:snapshot": "tsx scripts/backup-snapshot.ts",
    "reset:storage": "tsx scripts/cleanup-storage.ts",
    "reset:content": "tsx scripts/reset-content.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@aws-sdk/client-s3": "^3.600.0",
    "@aws-sdk/s3-request-presigner": "^3.600.0",
    "@citywhispers/config": "^0.0.1",
    "@citywhispers/types": "^0.0.1",
    "@clerk/fastify": "^3.1.29",
    "@fastify/cors": "^10.1.0",
    "@fastify/jwt": "^9.1.0",
    "@fastify/rate-limit": "^10.3.0",
    "@google-cloud/text-to-speech": "^6.4.1",
    "@google/generative-ai": "^0.24.1",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@sentry/node": "^8.0.0",
    "@upstash/redis": "^1.34.0",
    "bullmq": "^5.0.0",
    "dotenv": "^16.4.0",
    "fastify": "^5.8.5",
    "formdata-node": "^4.4.1",
    "ngeohash": "^0.6.3",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/ngeohash": "^0.6.8",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.0.0",
    "prettier": "^3.0.0",
    "prisma": "^7.7.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.7"
  }
}
