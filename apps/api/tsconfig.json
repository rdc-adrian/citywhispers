{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "bundler",
    "strict": true,
    "outDir": "dist",
    "rootDir": "src",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "ignoreDeprecations": "5.0",
    "paths": {
      "@citywhispers/types": ["../../packages/types/src"],
      "@citywhispers/config": ["../../packages/config/src"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
