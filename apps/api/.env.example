# ── Database ──────────────────────────────────────────────────────────────────
# Transaction-mode pooler URL (port 6543) — used for all queries.
DATABASE_URL="postgresql://postgres.xxx:password@aws-1-xxx.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Session-mode / direct URL (port 5432) — required for Prisma migrations.
DIRECT_URL="postgresql://postgres.xxx:password@aws-1-xxx.pooler.supabase.com:5432/postgres"

# ── Auth (Clerk) ───────────────────────────────────────────────────────────────
CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."

# ── Admin ─────────────────────────────────────────────────────────────────────
# Shared secret for all /admin/* routes (x-admin-key header).
ADMIN_API_KEY="your-admin-api-key-here"

# ── AI Generation (Sprint F) ──────────────────────────────────────────────────
# Provider selection: 'gemini' | 'anthropic'
# If omitted, auto-selects: Gemini if GEMINI_API_KEY is set, else Anthropic.
AI_PROVIDER="gemini"

# Google Gemini — free tier available at aistudio.google.com/apikey
# Used for whisper generation (gemini-2.0-flash) and scoring.
GEMINI_API_KEY="AIza..."

# Anthropic — paid API at console.anthropic.com (~$0.01/whisper with Sonnet)
# Used when AI_PROVIDER=anthropic or GEMINI_API_KEY is not set.
ANTHROPIC_API_KEY="sk-ant-..."

# ── TTS / Audio (Sprint G) ────────────────────────────────────────────────────
# Google Cloud Text-to-Speech — production narrator for MVP.
# Voice: en-SG-Neural2-A (Singapore English, Neural2 tier).
# Requires a GCP service account with the "Cloud Text-to-Speech API User" role.
#
# To obtain credentials:
#   1. GCP Console → IAM & Admin → Service Accounts → Create
#   2. Grant role: Cloud Text-to-Speech API User
#   3. Keys → Add Key → JSON → download
#   4. Copy values from the JSON key file into the three vars below.
#
# The private key typically contains literal \n sequences in the JSON —
# paste the raw value including those; the service normalises them on load.
GOOGLE_CLOUD_PROJECT_ID="your-gcp-project-id"
GOOGLE_CLOUD_CLIENT_EMAIL="tts-service@your-project.iam.gserviceaccount.com"
GOOGLE_CLOUD_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"

# ── Supabase Storage (Sprint G) ───────────────────────────────────────────────
# Supabase project URL and service role key — used to upload audio to the
# whisper-audio bucket. The service role key bypasses RLS; keep it server-side only.
# Audio is stored at: city/{citySlug}/whispers/{whisperId}.mp3
SUPABASE_URL="https://xxx.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV="development"
